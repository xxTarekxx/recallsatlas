# Copy to deploy.env.ps1 and fill in. deploy.env.ps1 is gitignored.

$VPS_HOST = "user@your-server.example"
$VPS_ROOT = "/var/www/html/recallsatlas"

# Optional: PM2 app name (default recallsatlas)
# $VPS_PM2_APP = "recallsatlas"

# Optional: private key path (if not using ssh-agent)
# $VPS_SSH_KEY = "$env:USERPROFILE\.ssh\id_ed25519"
