# Copy to deploy-backend.env (same folder as deploy-backend.sh) and adjust.
# deploy-backend.env is gitignored — do not commit secrets.
#
# DESTRUCTIVE — READ BEFORE USE
# deploy-backend.sh runs: rm -rf "$VPS_ROOT" && mkdir -p "$VPS_ROOT" on the VPS, then uploads
# from your laptop. If VPS_ROOT is wrong (typo, wrong server, or a path that is not ONLY your
# app backend), you can delete unrelated files on the server. Triple-check VPS_HOST and VPS_ROOT.

export VPS_HOST="root@216.225.194.194"
# Must be the dedicated remote folder for this app’s backend (package.json lives at VPS_ROOT/package.json):
export VPS_ROOT="/var/www/html/recallsatlas/backend"
# Optional:
# export VPS_SSH_KEY="$HOME/.ssh/id_ed25519"
# export VPS_PM2_APP="recallsatlas"
