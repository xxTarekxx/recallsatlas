# Copy to deploy.env.ps1 (same folder as this example). deploy.env.ps1 is gitignored.
#
# DESTRUCTIVE — deploy-backend.ps1 removes the entire remote $VPS_ROOT directory, then re-uploads.
# Wrong VPS_HOST or VPS_ROOT can wipe the wrong path on the server. Verify both before running.

$VPS_HOST = "user@your-vps.example"
# Dedicated remote backend folder (package.json at $VPS_ROOT/package.json):
$VPS_ROOT = "/var/www/html/recallsatlas/backend"
# Optional:
# $VPS_SSH_KEY = "C:\path\to\private_key"
# $VPS_PM2_APP = "recallsatlas"
